# Campus Operations Optimization System - Environment Template
# Copy to .env and fill in values. Never commit .env to version control.

# =============================================================================
# Required
# =============================================================================

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/campus

# Redis connection string
REDIS_URL=redis://localhost:6379

# =============================================================================
# Security (change in production)
# =============================================================================

# JWT signing key - generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# =============================================================================
# LLM (optional - support agent uses Groq for FAQ fallback)
# =============================================================================

# Groq API key from https://console.groq.com
GROQ_API_KEY=

# Model name
GROQ_MODEL=llama-3.1-70b-versatile

# =============================================================================
# Agent Tuning
# =============================================================================

# Max retries for agent operations
MAX_RETRIES=3

# Retry backoff factor (seconds)
RETRY_BACKOFF=2.0

# Agent workflow timeout (seconds)
AGENT_TIMEOUT=30

# Max supervisor iterations per event
MAX_ITERATIONS=10

# =============================================================================
# Logging & Monitoring
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Environment: development, staging, production
ENVIRONMENT=development

# Optional: PagerDuty for critical alerts
# PAGERDUTY_KEY=

# =============================================================================
# UI (Streamlit)
# =============================================================================

# API base URL for Streamlit (default: http://localhost:8000/api/v1)
# API_BASE_URL=http://localhost:8000/api/v1

# Health check URL for sidebar (default: http://localhost:8000/health)
# HEALTH_URL=http://localhost:8000/health
